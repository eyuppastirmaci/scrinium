{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://scrinium.dev/contracts/events/document-processing-failed.v1.json",
  "title": "DocumentProcessingFailed",
  "description": "Emitted by processing-service when document processing fails.",
  "type": "object",
  "required": ["id", "type", "version", "timestamp", "payload"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "type": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "title": "DocumentProcessingFailedPayload",
      "required": ["documentId", "reason"],
      "properties": {
        "documentId": {
          "type": "string",
          "format": "uuid"
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}

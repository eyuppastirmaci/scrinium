# Kafka
PROCESSING_KAFKA_BROKERS=localhost:9092
PROCESSING_KAFKA_IN_TOPIC=document.uploaded
PROCESSING_KAFKA_GROUP_ID=processing-service

# PostgreSQL
PROCESSING_DATABASE_URL=postgres://scrinium:scrinium@localhost:5433/processing
PROCESSING_DB_MAX_CONNECTIONS=5

# Object storage
PROCESSING_STORAGE_ENDPOINT=http://localhost:9000
PROCESSING_STORAGE_ACCESS_KEY=minioadmin
PROCESSING_STORAGE_SECRET_KEY=minioadmin
PROCESSING_STORAGE_BUCKET=documents

# OCR
# Use "tesseract" when it is available on PATH.
# On Windows, set this to your local executable path if Tesseract is not on PATH.
PROCESSING_TESSERACT_PATH=tesseract
PROCESSING_TESSERACT_LANGUAGES=tur+eng

# Redis
PROCESSING_REDIS_URL=redis://localhost:6379

# Concurrency (default: max(1, (cpu_cores - 1) / 2))
# PROCESSING_MAX_CONCURRENCY=4

# PDFium
# Directory containing pdfium.dll (Windows) or libpdfium.so (Linux).
# Falls back to system library if not found at the given path.
PROCESSING_PDFIUM_PATH=./
